# Copy to .env and adjust if needed.
# If Prisma still connects to the wrong host, clear a machine-level DATABASE_URL
# (dotenv does not override variables already set in the environment).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/physio_app"
# Multi-tenant app: all rows share one Postgres database/schema; isolation is by tenant_id (see migration).
# Hosted pooler (Neon serverless, PgBouncer transaction mode): point DATABASE_URL at the pooler.
# Migrations need a direct session (Prisma docs: DIRECT_URL); add directUrl to prisma/schema + prisma.config when you split URLs.
PORT=4000

# JWT signing secret — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET="change-me-in-development-only-use-long-secret"
JWT_EXPIRES_IN="7d"

# Short-lived token after password OK, before TOTP (must differ from JWT_SECRET in production).
PRE_2FA_JWT_SECRET="change-me-pre2fa-development-only"

# Optional: base64 of 32 raw bytes for AES-256-GCM on stored TOTP secrets (openssl rand -base64 32).
# If unset, a key is derived from JWT_SECRET (acceptable for local dev only).
# TOTP_ENCRYPTION_KEY=

# Issuer label in otpauth:// URIs (authenticator apps).
# TOTP_ISSUER="Thera Care"

# When true, ADMIN users without TOTP enabled cannot complete password login (bootstrap: enroll first with false).
REQUIRE_2FA_FOR_ADMIN=false

FRONTEND_ORIGIN="http://localhost:3000"

# Email: log to server (default) or SMTP. Links use FRONTEND_ORIGIN.
AUTH_EMAIL_MODE="log"
# AUTH_EMAIL_MODE=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Thera Care <noreply@example.com>"

PASSWORD_RESET_TTL_MINUTES=60
MAGIC_LINK_TTL_MINUTES=15

# Self-service signup: `true` / `false`, or omit (allowed in non-production, disabled in production).
ALLOW_PUBLIC_REGISTER="true"
