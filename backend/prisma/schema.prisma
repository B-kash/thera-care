// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum UserRole {
  ADMIN
  THERAPIST
  STAFF
}

enum EmailAuthTokenPurpose {
  PASSWORD_RESET
  MAGIC_LINK
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntityType {
  PATIENT
  APPOINTMENT
  TREATMENT_NOTE
  EXERCISE_PLAN
  EXERCISE_ITEM
  PROGRESS_RECORD
  USER
}

/// Clinic / org partition (Plan A: shared DB, row-level tenantId).
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  treatmentNotes   TreatmentNote[]
  exercisePlans    ExercisePlan[]
  exerciseItems    ExerciseItem[]
  progressRecords  ProgressRecord[]
  auditLogs        AuditLog[]

  @@map("tenants")
}

/// Application user (physiotherapist / staff).
model User {
  id                   String          @id @default(uuid())
  tenantId             String          @map("tenant_id")
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  email                String
  passwordHash         String?         @map("password_hash")
  displayName          String?         @map("display_name")
  role                 UserRole        @default(THERAPIST)
  active               Boolean         @default(true) @map("active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  patients             Patient[]
  appointmentsAsStaff Appointment[] @relation("AppointmentStaffUser")
  treatmentNotes      TreatmentNote[]
  exercisePlans       ExercisePlan[]
  progressRecords     ProgressRecord[]
  auditLogs           AuditLog[]
  emailAuthTokens     EmailAuthToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// One-time email links for password reset or passwordless login (hashed at rest).
model EmailAuthToken {
  id        String                 @id @default(uuid())
  userId    String                 @map("user_id")
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   EmailAuthTokenPurpose
  tokenHash String                 @map("token_hash") @db.VarChar(64)
  expiresAt DateTime               @map("expires_at")
  usedAt    DateTime?              @map("used_at")
  createdAt DateTime               @default(now()) @map("created_at")

  @@unique([tokenHash])
  @@index([userId, purpose])
  @@map("email_auth_tokens")
}

/// Append-only security / clinical audit trail (no updates from app).
model AuditLog {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorUserId String           @map("actor_user_id")
  actor       User             @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  action      AuditAction
  entityType  AuditEntityType  @map("entity_type")
  entityId    String           @map("entity_id")
  metadata    Json?
  ip          String?          @db.VarChar(128)
  userAgent   String?          @map("user_agent") @db.VarChar(512)
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}

model Patient {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String?
  phone           String?
  dateOfBirth     DateTime?      @map("date_of_birth") @db.Date
  notes           String?
  createdByUserId String?        @map("created_by_user_id")
  createdBy       User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  appointments    Appointment[]
  treatmentNotes  TreatmentNote[]
  exercisePlans   ExercisePlan[]
  progressRecords ProgressRecord[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("patients")
}

model Appointment {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientId   String             @map("patient_id")
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffUserId String?            @map("staff_user_id")
  staffUser   User?              @relation("AppointmentStaffUser", fields: [staffUserId], references: [id], onDelete: SetNull)
  startsAt    DateTime           @map("starts_at")
  endsAt      DateTime           @map("ends_at")
  status      AppointmentStatus  @default(SCHEDULED)
  notes       String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  treatmentNotes TreatmentNote[]

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@map("appointments")
}

model TreatmentNote {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientId      String       @map("patient_id")
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String       @map("author_user_id")
  author         User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  appointmentId  String?      @map("appointment_id")
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  subjective     String       @db.Text
  objective      String       @db.Text
  assessment     String       @db.Text
  plan           String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("treatment_notes")
}

model ExercisePlan {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientId      String         @map("patient_id")
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String         @map("author_user_id")
  author         User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  title          String
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  items          ExerciseItem[]

  @@index([tenantId])
  @@map("exercise_plans")
}

model ExerciseItem {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  exercisePlanId String       @map("exercise_plan_id")
  exercisePlan   ExercisePlan @relation(fields: [exercisePlanId], references: [id], onDelete: Cascade)
  name           String
  instructions   String?      @db.Text
  sets           Int?
  reps           Int?
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("exercise_items")
}

/// Snapshot of patient progress (pain, mobility) on a given calendar date.
model ProgressRecord {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientId      String   @map("patient_id")
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String   @map("author_user_id")
  author         User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  painLevel      Int      @map("pain_level")
  mobilityScore  Int?     @map("mobility_score")
  notes          String?  @db.Text
  recordedOn     DateTime @map("recorded_on") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, patientId, recordedOn])
  @@map("progress_records")
}
