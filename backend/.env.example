# Copy to .env and adjust if needed.
# If Prisma still connects to the wrong host, clear a machine-level DATABASE_URL
# (dotenv does not override variables already set in the environment).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/physio_app"
PORT=4000

# JWT signing secret — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET="change-me-in-development-only-use-long-secret"
JWT_EXPIRES_IN="7d"

FRONTEND_ORIGIN="http://localhost:3000"

# Email: log to server (default) or SMTP. Links use FRONTEND_ORIGIN.
AUTH_EMAIL_MODE="log"
# AUTH_EMAIL_MODE=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Thera Care <noreply@example.com>"

PASSWORD_RESET_TTL_MINUTES=60
MAGIC_LINK_TTL_MINUTES=15
