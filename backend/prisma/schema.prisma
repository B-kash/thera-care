// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum UserRole {
  ADMIN
  THERAPIST
  STAFF
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntityType {
  PATIENT
  APPOINTMENT
  TREATMENT_NOTE
  EXERCISE_PLAN
  EXERCISE_ITEM
  PROGRESS_RECORD
  USER
}

/// Application user (physiotherapist / staff).
model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String?         @map("password_hash")
  displayName          String?         @map("display_name")
  role                 UserRole        @default(THERAPIST)
  active               Boolean         @default(true) @map("active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  patients             Patient[]
  appointmentsAsStaff Appointment[] @relation("AppointmentStaffUser")
  treatmentNotes      TreatmentNote[]
  exercisePlans       ExercisePlan[]
  progressRecords     ProgressRecord[]
  auditLogs           AuditLog[]

  @@map("users")
}

/// Append-only security / clinical audit trail (no updates from app).
model AuditLog {
  id          String           @id @default(uuid())
  actorUserId String           @map("actor_user_id")
  actor       User             @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  action      AuditAction
  entityType  AuditEntityType  @map("entity_type")
  entityId    String           @map("entity_id")
  metadata    Json?
  ip          String?          @db.VarChar(128)
  userAgent   String?          @map("user_agent") @db.VarChar(512)
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}

model Patient {
  id              String         @id @default(uuid())
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String?
  phone           String?
  dateOfBirth     DateTime?      @map("date_of_birth") @db.Date
  notes           String?
  createdByUserId String?        @map("created_by_user_id")
  createdBy       User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  appointments    Appointment[]
  treatmentNotes  TreatmentNote[]
  exercisePlans   ExercisePlan[]
  progressRecords ProgressRecord[]

  @@map("patients")
}

model Appointment {
  id          String             @id @default(uuid())
  patientId   String             @map("patient_id")
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffUserId String?            @map("staff_user_id")
  staffUser   User?              @relation("AppointmentStaffUser", fields: [staffUserId], references: [id], onDelete: SetNull)
  startsAt    DateTime           @map("starts_at")
  endsAt      DateTime           @map("ends_at")
  status      AppointmentStatus  @default(SCHEDULED)
  notes       String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  treatmentNotes TreatmentNote[]

  @@map("appointments")
}

model TreatmentNote {
  id             String       @id @default(uuid())
  patientId      String       @map("patient_id")
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String       @map("author_user_id")
  author         User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  appointmentId  String?      @map("appointment_id")
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  subjective     String       @db.Text
  objective      String       @db.Text
  assessment     String       @db.Text
  plan           String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("treatment_notes")
}

model ExercisePlan {
  id             String         @id @default(uuid())
  patientId      String         @map("patient_id")
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String         @map("author_user_id")
  author         User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  title          String
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  items          ExerciseItem[]

  @@map("exercise_plans")
}

model ExerciseItem {
  id             String       @id @default(uuid())
  exercisePlanId String       @map("exercise_plan_id")
  exercisePlan   ExercisePlan @relation(fields: [exercisePlanId], references: [id], onDelete: Cascade)
  name           String
  instructions   String?      @db.Text
  sets           Int?
  reps           Int?
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("exercise_items")
}

/// Snapshot of patient progress (pain, mobility) on a given calendar date.
model ProgressRecord {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorUserId   String   @map("author_user_id")
  author         User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  painLevel      Int      @map("pain_level")
  mobilityScore  Int?     @map("mobility_score")
  notes          String?  @db.Text
  recordedOn     DateTime @map("recorded_on") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([patientId, recordedOn])
  @@map("progress_records")
}
