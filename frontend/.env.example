# Leave unset to use same-origin /api/* (Next rewrite → Nest; httpOnly cookie auth).
# Uncomment only if the browser must call the API on another origin (cross-site cookies need extra config).
# NEXT_PUBLIC_API_URL="http://localhost:4000"

# Used by next.config rewrites: /api/* → Nest (dev default matches docker-compose host port).
BACKEND_INTERNAL_URL="http://127.0.0.1:4000"

# PWA (FR-13): set to "true" with `next dev` or `next start` to register the service worker on http://localhost (off by default in dev).
# NEXT_PUBLIC_ENABLE_SW="true"
